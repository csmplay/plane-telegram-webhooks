# Logging level: ERROR, WARN, INFO, DEBUG
LOG_LEVEL=INFO
# Custon port to listen on (default 3111)
PORT=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Numeric chat ID where notifications are sent
TELEGRAM_CHAT_ID=
# Topic thread ID, only for supergroups with topics enabled (optional)
TELEGRAM_THREAD_ID=

# Secret from Plane webhook settings
PLANE_WEBHOOK_SECRET=

# All three must be set together, or none at all.
# Without them there are no issue links or creator names.
PLANE_BASE_URL=
PLANE_WORKSPACE_SLUG=
PLANE_API_KEY=

# Start message to be updated with health information, will be generated automatically if unset
# Set to 0 to disable
START_MESSAGE_ID=

# Deadline reminder settings (requires Plane API vars above)
# Local time HH:MM to run the check (default: 10:00)
DEADLINE_CHECK_TIME=
# Timezone for dates and times (e.g., Europe/Moscow, America/New_York)
TZ=
# Comma-separated days before deadline to notify (default: 7,2,0)
DEADLINE_NOTIFY_DAYS=
