# Logging level: ERROR, WARN, INFO, DEBUG
LOG_LEVEL=INFO
# Custon port to listen on (default 3111)
PORT=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Numeric chat ID where notifications are sent
TELEGRAM_CHAT_ID=
# Topic thread ID, only for supergroups with topics enabled (optional)
TELEGRAM_THREAD_ID=

# Secret from Plane webhook settings
PLANE_WEBHOOK_SECRET=

# All three must be set together, or none at all.
# Without them there are no issue links or creator names.
PLANE_BASE_URL=
PLANE_WORKSPACE_SLUG=
PLANE_API_KEY=
